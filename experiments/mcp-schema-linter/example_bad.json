{
  "tools": [
    {
      "name": "read_file",
      "description": "Read the full contents of a file from the local filesystem.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "file_path": {
            "type": "string",
            "description": "Absolute path to the file to read."
          },
          "encoding": {
            "type": "string",
            "description": "Character encoding, defaults to utf-8."
          }
        },
        "required": ["file_path"]
      }
    },
    {
      "name": "SearchFiles",
      "inputSchema": {
        "type": "object",
        "properties": {
          "x": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "description": "stuff"
          },
          "results": {
            "type": "array",
            "description": "The result set to filter before returning."
          }
        }
      }
    }
  ]
}
